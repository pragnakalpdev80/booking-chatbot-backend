# === Django Core ===
DEBUG=True
SECRET_KEY=your-secret-key-here

# === Google Calendar OAuth ===
# The path to the credentials file downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
# The redirect URI configured in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/calendar/oauth2callback/
# Set to 1 only for local development over HTTP (remove in production)
OAUTHLIB_INSECURE_TRANSPORT=1

# === Encryption ===
# Used to encrypt Google OAuth tokens in the database.
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-base64-fernet-key-here

# === Database ===
DB_NAME=calendar-chatbot
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# === Chatbot ===
# API key from Groq for the conversational AI model
GROQ_API_KEY=your-groq-api-key-here
